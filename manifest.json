{
  "author": "Katie Jobson <k.r.jobson@gmail.com>",
  "maintainer": "Katie Jobson <k.r.jobson@gmail.com>",
  "cite": "",
  "name": "greedypop",
  "source": "",
  "url": "https://github.com/kjobson-neuro/greedyPOP",
  "label": "PET-only Centiloid Processing",
  "description": "Gear for calculating centiloids from PET data, no MRI necessary",
  "command": "/flywheel/v0/pipeline_rPOP.sh",
  "license": "MIT",
  "version": "0.2.6",
  "environment": {
    "FLYWHEEL": "/flywheel/v0",
    "PYTHON_GET_PIP_URL": "https://github.com/pypa/get-pip/raw/0d8570dc44796f4369b652222cf176b3db6ac70e/public/get-pip.py",
    "LANG": "en_US.UTF-8",
    "PYTHON_VERSION": "3.9",
    "OS": "Linux",
    "AFNI_PLUGINPATH": "/opt/afni/install",
    "PATH": "/usr/local/miniconda/bin:/opt/itksnap/bin:/opt/freesurfer/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
    "DEBIAN_FRONTEND": "noninteractive",
    "LC_ALL": "C.UTF-8",
    "PWD": "/",
    "BASEDIR": "/opt/base",
    "CONDA_DIR": "/opt/miniconda-latest",
    "MKL_NUM_THREADS": "1",
    "OMP_NUM_THREADS": "1",
    "PYTHONNOUSERSITE": "1",
    "TZ": "Etc/UTC",
    "LD_LIBRARY_PATH": "/usr/lib/x86_64-linux-gnu:/usr/local/miniconda/lib:",
    "GLIBCXX_FORCE_NEW": "1",
    "MKL_DEBUG_CPU_TYPE": "5",
    "LD_PRELOAD": "/usr/lib/x86_64-linux-gnu/libgomp.so.1 /usr/lib/x86_64-linux-gnu/libatomic.so.1",
    "ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS": "1",
    "MINC_LIB_DIR": "/opt/freesurfer/mni/lib",
    "FREESURFER_HOME": "/opt/freesurfer",
    "MINC_BIN_DIR": "/opt/freesurfer/mni/bin",
    "FUNCTIONALS_DIR": "/opt/freesurfer/sessions",
    "PERL5LIB": "/opt/freesurfer/mni/lib/perl5/5.8.5",
    "MNI_DIR": "/opt/freesurfer/mni",
    "MNI_PERL5LIB": "/opt/freesurfer/mni/lib/perl5/5.8.5",
    "LOCAL_DIR": "/opt/freesurfer/local",
    "FS_OVERRIDE": "0",
    "FSF_OUTPUT_FORMAT": "nii.gz",
    "MNI_DATAPATH": "/opt/freesurfer/mni/data",
    "SUBJECTS_DIR": "/opt/freesurfer/subjects",
    "OPENBLAS_NUM_THREADS": "1"
  },
  "custom": {
    "gear-builder": {
      "category": "analysis",
      "image": "kjobson/greedypop:0.2.6"
    },
    "flywheel": {
      "suite": "BrainScienceCenter"
    }
  },
  "inputs": {
    "petdata": {
      "base": "file",
      "description": "Full path to the PET input file - NIfTI only",
      "optional": false
    }
  },
  "config": {
    "origin": {
      "default": "Keep",
      "enum": [
        "Reset",
        "Keep"
      ],
      "type": "string"
    },
    "tracer": {
      "default": "Florbetaben",
      "enum": [
        "Florbetapir",
        "Florbetaben",
        "Flutemetamol"
      ],
      "type": "string"
    }
  }
}